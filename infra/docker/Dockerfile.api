FROM python:3.12-slim

WORKDIR /app

# Install poker-core
COPY packages/poker-core /app/packages/poker-core
RUN pip install -e /app/packages/poker-core

# Install solver engine
COPY apps/solver /app/apps/solver

# Install API
COPY apps/api/requirements.txt /app/requirements.txt
RUN pip install -r /app/requirements.txt

COPY apps/api /app/apps/api

ENV PYTHONPATH=/app:/app/apps/api
EXPOSE 8001

CMD ["uvicorn", "apps.api.main:app", "--host", "0.0.0.0", "--port", "8001"]
